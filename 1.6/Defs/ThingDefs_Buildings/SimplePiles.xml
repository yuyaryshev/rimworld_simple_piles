<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <DesignatorDropdownGroupDef>
    <defName>SimplePiles_ResourcePile</defName>
  </DesignatorDropdownGroupDef>

  <ThingDef Name="SimplePileBase" ParentName="AdaptiveStorageBase" Abstract="True">
    <fillPercent>0.2</fillPercent>
    <size>(1,1)</size>
    <rotatable>true</rotatable>
    <designatorDropdown>SimplePiles_ResourcePile</designatorDropdown>
    <uiIconPath>SimplePiles/SmallLogPile/SmallLogPile_UI</uiIconPath>
    <uiIconScale>1.5</uiIconScale>
    <graphicData>
      <texPath>SimplePiles/SmallLogPile/SmallLogPile_H2</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1.5,1.5)</drawSize>
      <drawRotated>false</drawRotated>
      <drawOffsetNorth>0,0,0.125</drawOffsetNorth>
      <drawOffsetSouth>0,0,-0.125</drawOffsetSouth>
      <drawOffsetEast>0,0.125,0</drawOffsetEast>
      <drawOffsetWest>0,-0.125,0</drawOffsetWest>
    </graphicData>
    <costStuffCount>0</costStuffCount>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <WorkToBuild>0</WorkToBuild>
      <Beauty>0</Beauty>
      <Flammability>1.0</Flammability>
      <Mass>1</Mass>
    </statBases>
    <building>
      <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
      <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
      <maxItemsInCell>1</maxItemsInCell>
      <relatedBuildCommands>
        <li>SimplePile_Wood</li>
        <li>SimplePile_Steel</li>
        <li>SimplePile_Plasteel</li>
        <li>SimplePile_StoneBlocks</li>
        <li>SimplePile_Components</li>
        <li>SimplePile_AdvancedComponents</li>
        <li>SimplePile_Gold</li>
        <li>SimplePile_Silver</li>
        <li>SimplePile_Medicine</li>
      </relatedBuildCommands>
    </building>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsFurniture</li>
    </thingCategories>
  </ThingDef>

  <ThingDef ParentName="SimplePileBase">
    <defName>SimplePile_Wood</defName>
    <label>wood pile spot</label>
    <description>A one-stack pile spot for wood. Built from 1 wood.</description>
    <building>
      <defaultStorageSettings>
        <priority>Important</priority>
        <filter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </filter>
      </defaultStorageSettings>
      <fixedStorageSettings>
        <filter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </filter>
      </fixedStorageSettings>
    </building>
  </ThingDef>

